{
  "name": "dcx-dev",
  "build": {
	  "dockerfile": "Dockerfile"
  },
  "features": {
	"ghcr.io/devcontainers/features/docker-in-docker:2": {
		"moby": false
	}
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "postCreateCommand": "go mod download"
}
